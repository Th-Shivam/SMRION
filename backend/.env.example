# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=SMRION
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost      # use 'postgres' inside Docker
POSTGRES_PORT=5432
POSTGRES_USER=smrion
POSTGRES_PASSWORD=smrion_secret
POSTGRES_DB=smrion_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost         # use 'redis' inside Docker
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_SECONDS=3600

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost         # use 'qdrant' inside Docker
QDRANT_PORT=6333
QDRANT_COLLECTION=smrion_memories

# ── Celery ────────────────────────────────────────────────────────────────────
# Broker and result backend default to the Redis URL computed from REDIS_* vars.
# Override here only if using a separate broker instance.
# CELERY_BROKER_URL=redis://localhost:6379/0

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
